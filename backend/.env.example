# ── Redline Backend Environment ──────────────────────────────────────────────

# CORS origins (comma-separated, use * for open dev)
CORS_ORIGINS=*

# SQLite database path (relative to backend dir)
DB_PATH=./redline.db

# Rate limiting — requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# OpenAI (optional — can also be passed per-request from UI)
OPENAI_API_KEY=

# Default Ollama URL
OLLAMA_BASE_URL=http://localhost:11434

# Debug mode
DEBUG=false
