# ── Redline Root Environment ──────────────────────────────────────────────────
# Copy this to .env and fill in values before running docker-compose

# ── Backend ───────────────────────────────────────────────────────────────────

# OpenAI API key (optional - can also be entered per-request in the UI)
OPENAI_API_KEY=

# CORS allowed origins (comma-separated). Use * for open, or specify your frontend URL
CORS_ORIGINS=*

# Requests per minute per IP before rate limiting kicks in
RATE_LIMIT_PER_MINUTE=60

# ── Frontend ──────────────────────────────────────────────────────────────────

# URL the browser uses to reach the backend API
# Local dev:    http://localhost:8000
# Docker:       http://localhost:8000
# Production:   https://your-backend.railway.app
VITE_API_URL=http://localhost:8000

# ── Ollama (if running on host, not in Docker) ────────────────────────────────
# If using Docker + host Ollama, set this in the UI to:
# http://host.docker.internal:11434
